# --- Telegram ---
BOT_TOKEN=8696220204:AAEWR54FBA_9yDxocdbHnJWXwRL599H2wz0
TRAINER_TG_ID=707919898         # Telegram id тренера (её id)

# --- База / Redis ---
# host=localhost — для запуска alembic и бота С ТВОЕЙ МАШИНЫ (контейнеры
# публикуют порты на localhost). Внутри docker compose сервис bot сам
# подменит host на db/redis (см. environment в docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://fitbot:change_me@localhost:5433/fitbot
REDIS_URL=redis://localhost:6379/0

# --- Параметры postgres-контейнера ---
POSTGRES_USER=fitbot
POSTGRES_PASSWORD=change_me
POSTGRES_DB=fitbot

# Порты, публикуемые на хост. Если 5432/6379 заняты другим Postgres/Redis —
# поставь свободный (напр. DB_PORT=5433) и синхронно поправь порт в DATABASE_URL.
DB_PORT=5433
REDIS_PORT=6379

# --- YooKassa (Phase 0 — можно пусто) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
